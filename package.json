{
  "name": "opencode-linear",
  "version": "1.0.3",
  "description": "Linear issue workflow plugin for OpenCode - sync tasks, track progress, manage issue lifecycle",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "commands",
    "examples",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "postinstall": "node ./scripts/postinstall.js",
    "preuninstall": "node ./scripts/preuninstall.js",
    "build": "tsc",
    "check": "tsc --noEmit",
    "fmt": "prettier --write .",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "opencode",
    "plugin",
    "linear",
    "issue-tracking",
    "workflow",
    "productivity"
  ],
  "author": "gxlife",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gxlife/opencode-linear.git"
  },
  "bugs": {
    "url": "https://github.com/gxlife/opencode-linear/issues"
  },
  "homepage": "https://github.com/gxlife/opencode-linear#readme",
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.0.0",
    "@schpet/linear-cli": "^1.11.0"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bun": "^1.0.0",
    "typescript": "^5.0.0"
  }
}
